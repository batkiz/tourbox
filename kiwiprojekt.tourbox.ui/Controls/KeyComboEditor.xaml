<UserControl x:Class="kiwiprojekt.tourbox.ui.Controls.KeyComboEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <UserControl.Resources>
        <Style x:Key="ModCheck" TargetType="CheckBox">
            <Setter Property="Width" Value="55"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Modifier checkboxes -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="修饰键:" VerticalAlignment="Center" Width="50" FontSize="11"
                       Foreground="#666"/>
            <CheckBox x:Name="ChkCtrl" Content="Ctrl" Style="{StaticResource ModCheck}"
                      Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
            <CheckBox x:Name="ChkShift" Content="Shift" Style="{StaticResource ModCheck}"
                      Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
            <CheckBox x:Name="ChkAlt" Content="Alt" Style="{StaticResource ModCheck}"
                      Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
            <CheckBox x:Name="ChkWin" Content="Win" Style="{StaticResource ModCheck}"
                      Checked="Modifier_Changed" Unchecked="Modifier_Changed"/>
        </StackPanel>

        <!-- Main key + record -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="主键:" VerticalAlignment="Center" FontSize="11" Foreground="#666"/>

            <ComboBox Grid.Column="1" x:Name="CboKey" IsEditable="True" Height="26"
                      Text="{Binding ElementName=root, Path=MainKey, UpdateSourceTrigger=PropertyChanged}"
                      SelectionChanged="CboKey_SelectionChanged"
                      KeyDown="CboKey_KeyDown"
                      ToolTip="输入或选择键名，也可点击右侧录制按钮捕获按键">
                <ComboBoxItem Content="A"/><ComboBoxItem Content="B"/><ComboBoxItem Content="C"/>
                <ComboBoxItem Content="D"/><ComboBoxItem Content="E"/><ComboBoxItem Content="F"/>
                <ComboBoxItem Content="G"/><ComboBoxItem Content="H"/><ComboBoxItem Content="I"/>
                <ComboBoxItem Content="J"/><ComboBoxItem Content="K"/><ComboBoxItem Content="L"/>
                <ComboBoxItem Content="M"/><ComboBoxItem Content="N"/><ComboBoxItem Content="O"/>
                <ComboBoxItem Content="P"/><ComboBoxItem Content="Q"/><ComboBoxItem Content="R"/>
                <ComboBoxItem Content="S"/><ComboBoxItem Content="T"/><ComboBoxItem Content="U"/>
                <ComboBoxItem Content="V"/><ComboBoxItem Content="W"/><ComboBoxItem Content="X"/>
                <ComboBoxItem Content="Y"/><ComboBoxItem Content="Z"/>
                <ComboBoxItem Content="0"/><ComboBoxItem Content="1"/><ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/><ComboBoxItem Content="4"/><ComboBoxItem Content="5"/>
                <ComboBoxItem Content="6"/><ComboBoxItem Content="7"/><ComboBoxItem Content="8"/>
                <ComboBoxItem Content="9"/>
                <ComboBoxItem Content="F1"/><ComboBoxItem Content="F2"/><ComboBoxItem Content="F3"/>
                <ComboBoxItem Content="F4"/><ComboBoxItem Content="F5"/><ComboBoxItem Content="F6"/>
                <ComboBoxItem Content="F7"/><ComboBoxItem Content="F8"/><ComboBoxItem Content="F9"/>
                <ComboBoxItem Content="F10"/><ComboBoxItem Content="F11"/><ComboBoxItem Content="F12"/>
                <ComboBoxItem Content="Space"/>
                <ComboBoxItem Content="Tab"/>
                <ComboBoxItem Content="Enter"/>
                <ComboBoxItem Content="Backspace"/>
                <ComboBoxItem Content="Delete"/>
                <ComboBoxItem Content="Insert"/>
                <ComboBoxItem Content="Home"/>
                <ComboBoxItem Content="End"/>
                <ComboBoxItem Content="PageUp"/>
                <ComboBoxItem Content="PageDown"/>
                <ComboBoxItem Content="Up"/>
                <ComboBoxItem Content="Down"/>
                <ComboBoxItem Content="Left"/>
                <ComboBoxItem Content="Right"/>
                <ComboBoxItem Content="Escape"/>
                <ComboBoxItem Content="PrintScreen"/>
                <ComboBoxItem Content="ScrollLock"/>
                <ComboBoxItem Content="Pause"/>
                <ComboBoxItem Content="CapsLock"/>
                <ComboBoxItem Content="NumLock"/>
                <ComboBoxItem Content="BrowserBack"/>
                <ComboBoxItem Content="BrowserForward"/>
                <ComboBoxItem Content="BrowserRefresh"/>
                <ComboBoxItem Content="BrowserHome"/>
                <ComboBoxItem Content="BrowserSearch"/>
                <ComboBoxItem Content="BrowserFavorites"/>
                <ComboBoxItem Content="VolumeMute"/>
                <ComboBoxItem Content="VolumeDown"/>
                <ComboBoxItem Content="VolumeUp"/>
                <ComboBoxItem Content="MediaNext"/>
                <ComboBoxItem Content="MediaPrev"/>
                <ComboBoxItem Content="MediaStop"/>
                <ComboBoxItem Content="MediaPlay"/>
                <ComboBoxItem Content="LaunchMail"/>
                <ComboBoxItem Content="LaunchMedia"/>
                <ComboBoxItem Content="LaunchApp1"/>
                <ComboBoxItem Content="LaunchApp2"/>
                <ComboBoxItem Content="Oem1"/>  <!-- ;: -->
                <ComboBoxItem Content="Oem2"/>  <!-- /? -->
                <ComboBoxItem Content="Oem3"/>  <!-- `~ -->
                <ComboBoxItem Content="Oem4"/>  <!-- [{ -->
                <ComboBoxItem Content="Oem5"/>  <!-- \| -->
                <ComboBoxItem Content="Oem6"/>  <!-- ]} -->
                <ComboBoxItem Content="Oem7"/>  <!-- '" -->
                <ComboBoxItem Content="OemComma"/>   <!-- ,< -->
                <ComboBoxItem Content="OemPeriod"/>  <!-- .> -->
                <ComboBoxItem Content="OemMinus"/>   <!-- -_ -->
                <ComboBoxItem Content="OemPlus"/>    <!-- =+ -->
            </ComboBox>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="BtnRecord" Content="● 录制" Width="70" Height="26"
                        Margin="6,0,4,0" Click="BtnRecord_Click"
                        Background="#FF5722" Foreground="White" BorderThickness="0"
                        ToolTip="点击后按下键盘按键来捕获"/>
                <Button x:Name="BtnClear" Content="✕" Width="28" Height="26"
                        Click="BtnClear_Click"
                        ToolTip="清除"/>
            </StackPanel>
        </Grid>

        <!-- Preview -->
        <TextBlock x:Name="TxtPreview" FontSize="11" Margin="0,4,0,0" Foreground="#888">
            <Run Text="组合键: "/>
            <Run x:Name="RunPreview" Text="(未设置)" FontWeight="SemiBold" Foreground="#333"/>
        </TextBlock>
    </StackPanel>
</UserControl>

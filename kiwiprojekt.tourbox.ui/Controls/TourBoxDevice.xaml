<UserControl x:Class="kiwiprojekt.tourbox.ui.Controls.TourBoxDevice"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="480" d:DesignWidth="560">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BodyFill" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BodyStroke" Color="#555"/>
        <SolidColorBrush x:Key="KnobFill" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="KnobStroke" Color="#777"/>
        <SolidColorBrush x:Key="BtnOff" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="BtnStroke" Color="#666"/>
        <SolidColorBrush x:Key="TextLight" Color="#DDD"/>
        <SolidColorBrush x:Key="TextDim" Color="#999"/>

        <Style x:Key="DeviceBtn" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BtnOff}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BtnStroke}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DeviceKnob" TargetType="Ellipse">
            <Setter Property="Fill" Value="{StaticResource KnobFill}"/>
            <Setter Property="Stroke" Value="{StaticResource KnobStroke}"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource BodyFill}"
            BorderBrush="{StaticResource BodyStroke}"
            BorderThickness="2" CornerRadius="24" Padding="0">
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== LEFT: D-Pad + Rotaries ===== -->

            <!-- D-Pad -->
            <Border Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"
                    Background="#252525" CornerRadius="10" Padding="8">
                <Grid Width="96" Height="76">
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DeviceBtn}"
                            Tag="Up" CornerRadius="4" Margin="2"/>
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource DeviceBtn}"
                            Tag="Left" CornerRadius="4" Margin="2"/>
                    <Border Grid.Row="1" Grid.Column="1" Background="#2A2A2A" CornerRadius="4" Margin="2"/>
                    <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource DeviceBtn}"
                            Tag="Right" CornerRadius="4" Margin="2"/>
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource DeviceBtn}"
                            Tag="Down" CornerRadius="4" Margin="2"/>
                </Grid>
            </Border>

            <!-- Knob -->
            <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,8,10">
                <TextBlock Text="Knob" FontSize="10" Foreground="{StaticResource TextDim}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <Ellipse Width="62" Height="62" Style="{StaticResource DeviceKnob}"
                         Tag="Knob" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Scroll -->
            <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                <TextBlock Text="Scroll" FontSize="10" Foreground="{StaticResource TextDim}"
                           HorizontalAlignment="Center" Margin="0,8,0,4"/>
                <Ellipse Width="56" Height="56" Style="{StaticResource DeviceKnob}"
                         Tag="Scroll" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Dial -->
            <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Bottom" Margin="0,0,8,10">
                <TextBlock Text="Dial" FontSize="10" Foreground="{StaticResource TextDim}"
                           HorizontalAlignment="Center" Margin="0,8,0,4"/>
                <Ellipse Width="56" Height="56" Style="{StaticResource DeviceKnob}"
                         Tag="Dial" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ===== RIGHT: Buttons ===== -->

            <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top -->
                <Border Grid.Row="0" Style="{StaticResource DeviceBtn}"
                        Tag="Top" CornerRadius="8" Height="38" Margin="0,0,0,6"/>
                <!-- Tall -->
                <Border Grid.Row="1" Style="{StaticResource DeviceBtn}"
                        Tag="Tall" CornerRadius="12" Margin="0,6"/>
                <!-- Short -->
                <Border Grid.Row="1" Style="{StaticResource DeviceBtn}"
                        Tag="Short" CornerRadius="8" Height="40" Margin="0,6,0,0"
                        VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Bottom row -->
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,6,0,0">
                <!-- Side -->
                <Border Style="{StaticResource DeviceBtn}"
                        Tag="Side" CornerRadius="8" Height="36"/>
                <!-- C1 / Tour / C2 -->
                <UniformGrid Columns="3" Margin="0,6,0,0">
                    <Border Style="{StaticResource DeviceBtn}"
                            Tag="C1" CornerRadius="6" Height="34" Margin="0,0,3,0"/>
                    <Border Style="{StaticResource DeviceBtn}"
                            Tag="Tour" CornerRadius="6" Height="34" Margin="2,0"/>
                    <Border Style="{StaticResource DeviceBtn}"
                            Tag="C2" CornerRadius="6" Height="34" Margin="3,0,0,0"/>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

<Window x:Class="kiwiprojekt.tourbox.ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:kiwiprojekt.tourbox.ui.Controls"
        xmlns:converters="clr-namespace:kiwiprojekt.tourbox.ui.Converters"
        Title="TourBox 配置" Height="700" Width="1050"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="Green" Color="#4CAF50"/>
        <SolidColorBrush x:Key="Red" Color="#F44336"/>
        <SolidColorBrush x:Key="Orange" Color="#FF9800"/>
        <SolidColorBrush x:Key="PanelBg" Color="#F8F8F8"/>
        <SolidColorBrush x:Key="Border" Color="#E0E0E0"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar: Connection -->
        <Border Grid.Row="0" Padding="10,8" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <!-- Status dot -->
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Connected">
                                        <Setter Property="Fill" Value="{StaticResource Green}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Connecting">
                                        <Setter Property="Fill" Value="{StaticResource Orange}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Disconnected">
                                        <Setter Property="Fill" Value="{StaticResource Red}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Error">
                                        <Setter Property="Fill" Value="{StaticResource Red}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Device.StatusMessage}" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,16,0"/>

                    <ComboBox ItemsSource="{Binding Device.AvailablePorts}"
                              SelectedItem="{Binding Device.PortName}"
                              Width="110" IsEditable="True" Margin="0,0,6,0"/>
                    <Button x:Name="BtnConnect" Content="连接" Width="60"
                            Command="{Binding ConnectCommand}" Padding="4,2"/>
                    <Button x:Name="BtnDisconnect" Content="断开" Width="60"
                            Command="{Binding DisconnectCommand}" Padding="4,2"/>
                </StackPanel>

                <TextBlock Text="{Binding Device.LastEvent}" HorizontalAlignment="Right"
                           VerticalAlignment="Center" FontSize="11" Foreground="#888"
                           MaxWidth="200" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Main area: Left=Device, Right=ControlsList+Editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="340"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="380"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Device + quick status -->
            <Border Grid.Column="0" Padding="14" Background="{StaticResource PanelBg}">
                <StackPanel>
                    <controls:TourBoxDevice VisualState="{Binding Visual}"
                                            Mappings="{Binding MappingPreviews}"
                                            ControlClicked="Device_ControlClicked"/>
                    <TextBlock Text="🖱 点击控件编辑  |  绿:按下  蓝:旋钮" FontSize="10"
                               Foreground="#AAA" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="#DDD"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- RIGHT: Controls list + Editor -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*" MinHeight="180"/>
                </Grid.RowDefinitions>

                <!-- Controls Table -->
                <Border Grid.Row="0" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <ListView x:Name="MappingList" ItemsSource="{Binding MappingRows}"
                              SelectionChanged="MappingList_SelectionChanged"
                              BorderThickness="0" Background="White">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="控件" Width="90" DisplayMemberBinding="{Binding ControlName}"/>
                                <GridViewColumn Header="动作" Width="250" DisplayMemberBinding="{Binding Action}"/>
                                <GridViewColumn Header="模式" Width="55" DisplayMemberBinding="{Binding Mode}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" Background="#DDD"
                              HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                <!-- Editor Panel -->
                <Border Grid.Row="2" Padding="12" Background="{StaticResource PanelBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontSize="15" FontWeight="Bold">
                                <Run Text="编辑: "/>
                                <Run Text="{Binding Editor.ControlName, Mode=OneWay, FallbackValue='(选择控件)'}"
                                     Foreground="#2196F3"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,8" Orientation="Horizontal">
                            <TextBlock Text="动作类型:" VerticalAlignment="Center" Width="70"/>
                            <ComboBox ItemsSource="{Binding Editor.ActionTypes}"
                                      SelectedItem="{Binding Editor.ActionType, UpdateSourceTrigger=PropertyChanged}"
                                      Width="140"/>
                            <TextBlock Text="模式:" VerticalAlignment="Center" Width="40" Margin="16,0,0,0"
                                       Visibility="{Binding Editor.ShowMode, Converter={StaticResource BoolToVis}}"/>
                            <ComboBox ItemsSource="{Binding Editor.Modes}"
                                      SelectedItem="{Binding Editor.Mode, UpdateSourceTrigger=PropertyChanged}"
                                      Width="70"
                                      Visibility="{Binding Editor.ShowMode, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Keyboard -->
                        <StackPanel Grid.Row="2" Visibility="{Binding Editor.IsKeyboard, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="按键组合 (例: VK_CONTROL+VK_C)" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Editor.KeyCombo, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" Height="28"/>
                        </StackPanel>

                        <!-- Mouse Click -->
                        <StackPanel Grid.Row="2" Visibility="{Binding Editor.IsMouseClick, Converter={StaticResource BoolToVis}}">
                            <ComboBox ItemsSource="{Binding Editor.MouseButtons}"
                                      SelectedItem="{Binding Editor.MouseButton}"
                                      Width="140" Height="28"/>
                        </StackPanel>

                        <!-- Mouse Scroll -->
                        <StackPanel Grid.Row="2" Visibility="{Binding Editor.IsMouseScroll, Converter={StaticResource BoolToVis}}">
                            <ComboBox ItemsSource="{Binding Editor.ScrollDirections}"
                                      SelectedItem="{Binding Editor.ScrollDirection}"
                                      Width="140" Height="28"/>
                        </StackPanel>

                        <!-- Text -->
                        <StackPanel Grid.Row="2" Visibility="{Binding Editor.IsText, Converter={StaticResource BoolToVis}}">
                            <TextBox Text="{Binding Editor.Text, UpdateSourceTrigger=PropertyChanged}"
                                     Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>

                        <!-- Rotary CW/CCW -->
                        <StackPanel Grid.Row="3" Margin="0,8,0,0"
                                    Visibility="{Binding Editor.IsRotary, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="顺时针 ▲" FontWeight="SemiBold" Margin="0,0,0,2"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Editor.ActionTypes}"
                                          SelectedItem="{Binding Editor.CwActionType, UpdateSourceTrigger=PropertyChanged}"
                                          Width="120"/>
                                <TextBox Grid.Column="1" Text="{Binding Editor.CwKeyCombo, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas" Height="26" Margin="6,0,0,0"
                                         Visibility="{Binding Editor.IsCwKeyboard, Converter={StaticResource BoolToVis}}"/>
                            </Grid>

                            <TextBlock Text="逆时针 ▼" FontWeight="SemiBold" Margin="0,4,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Editor.ActionTypes}"
                                          SelectedItem="{Binding Editor.CcwActionType, UpdateSourceTrigger=PropertyChanged}"
                                          Width="120"/>
                                <TextBox Grid.Column="1" Text="{Binding Editor.CcwKeyCombo, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas" Height="26" Margin="6,0,0,0"
                                         Visibility="{Binding Editor.IsCcwKeyboard, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                                    Margin="0,8,0,0">
                            <Button Content="保存" Width="70" Height="30"
                                    Click="EditorSave_Click"
                                    Background="#2196F3" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Padding="6,4" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding ConfigPath}" FontSize="10" Foreground="#AAA"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>

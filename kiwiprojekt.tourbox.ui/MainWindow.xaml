<Window x:Class="kiwiprojekt.tourbox.ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:kiwiprojekt.tourbox.ui.Controls"
        Title="TourBox 配置" Height="600" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="ConnectedBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="DisconnectedBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="ConnectingBrush" Color="#FF9800"/>

        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header / Connection Panel -->
        <Border Grid.Row="0" Padding="12" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Connected">
                                        <Setter Property="Fill" Value="{StaticResource ConnectedBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Connecting">
                                        <Setter Property="Fill" Value="{StaticResource ConnectingBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Disconnected">
                                        <Setter Property="Fill" Value="{StaticResource DisconnectedBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Error">
                                        <Setter Property="Fill" Value="{StaticResource DisconnectedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Device.StatusMessage}" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Device.AvailablePorts}"
                              SelectedItem="{Binding Device.PortName}"
                              Width="120" Margin="0,0,8,0"
                              IsEditable="True"
                              ToolTip="选择串口"/>
                    <Button x:Name="BtnConnect" Content="连接" Width="80"
                            Command="{Binding ConnectCommand}"
                            Visibility="Visible"/>
                    <Button x:Name="BtnDisconnect" Content="断开" Width="80"
                            Command="{Binding DisconnectCommand}"
                            Visibility="Visible"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Device.LastEvent}" FontSize="12"
                               Foreground="#666" MaxWidth="200"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Device Visual + Key Tester -->
        <Border Grid.Row="1" Padding="16" BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,8">
            <controls:TourBoxDevice VisualState="{Binding Visual}"/>
        </Border>

        <!-- Event Log -->
        <Border Grid.Row="2" Padding="8" BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="事件日志" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <ListView Grid.Row="1" ItemsSource="{Binding EventLog}"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas" FontSize="12"
                                       Margin="2"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Padding="8" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="配置文件:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding ConfigPath}" VerticalAlignment="Center"
                           Foreground="#666" FontSize="11"
                           TextTrimming="CharacterEllipsis" MaxWidth="500"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

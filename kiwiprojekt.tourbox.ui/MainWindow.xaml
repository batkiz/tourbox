<Window x:Class="kiwiprojekt.tourbox.ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:kiwiprojekt.tourbox.ui.Controls"
        xmlns:converters="clr-namespace:kiwiprojekt.tourbox.ui.Converters"
        Title="TourBox 配置" Height="580" Width="780"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Connection -->
        <Border Grid.Row="0" Padding="8,6" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Connected">
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Connecting">
                                        <Setter Property="Fill" Value="#FF9800"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Disconnected">
                                        <Setter Property="Fill" Value="#F44336"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Device.ConnectionState}" Value="Error">
                                        <Setter Property="Fill" Value="#F44336"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Device.StatusMessage}" VerticalAlignment="Center"
                               FontWeight="SemiBold" Width="140"/>
                    <ComboBox ItemsSource="{Binding Device.AvailablePorts}"
                              SelectedItem="{Binding Device.PortName}"
                              Width="90" IsEditable="True" Margin="8,0,4,0"/>
                    <Button x:Name="BtnConnect" Content="连接" Width="50"
                            Command="{Binding ConnectCommand}" Padding="4,2"/>
                    <Button x:Name="BtnDisconnect" Content="断开" Width="50"
                            Command="{Binding DisconnectCommand}" Padding="4,2"/>
                </StackPanel>
                <TextBlock Text="{Binding Device.LastEvent}" DockPanel.Dock="Right"
                           VerticalAlignment="Center" FontSize="11" Foreground="#888"
                           MaxWidth="180" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main: Table + Editor -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <!-- Controls Table -->
            <ListView Grid.Row="0" x:Name="MappingList" ItemsSource="{Binding MappingRows}"
                      SelectionChanged="MappingList_SelectionChanged"
                      BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="控件" Width="80"
                                        DisplayMemberBinding="{Binding ControlName}"/>
                        <GridViewColumn Header="动作" Width="340">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Action}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="模式" Width="60"
                                        DisplayMemberBinding="{Binding Mode}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <GridSplitter Grid.Row="1" Height="4" Background="#E0E0E0"
                          HorizontalAlignment="Stretch"/>

            <!-- Editor Panel -->
            <Border Grid.Row="2" Padding="12" Background="#FAFAFA"
                    BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" Margin="0,0,0,10">
                            <Run Text="编辑: "/>
                            <Run Text="{Binding Editor.ControlName, Mode=OneWay, FallbackValue='(选择左侧控件)'}"
                                 Foreground="#2196F3"/>
                        </TextBlock>

                        <!-- Action type + Mode -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="动作:" VerticalAlignment="Center" Width="45"/>
                            <ComboBox ItemsSource="{Binding Editor.ActionTypes}"
                                      SelectedItem="{Binding Editor.ActionType, UpdateSourceTrigger=PropertyChanged}"
                                      Width="130" Margin="0,0,12,0"/>
                            <TextBlock Text="模式:" VerticalAlignment="Center" Width="40"
                                       Visibility="{Binding Editor.ShowMode, Converter={StaticResource BoolToVis}}"/>
                            <ComboBox ItemsSource="{Binding Editor.Modes}"
                                      SelectedItem="{Binding Editor.Mode, UpdateSourceTrigger=PropertyChanged}"
                                      Width="70"
                                      Visibility="{Binding Editor.ShowMode, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Keyboard -->
                        <Grid Grid.Row="2" Visibility="{Binding Editor.IsKeyboard, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="按键:" VerticalAlignment="Top" Margin="0,6,0,0"/>
                            <controls:KeyComboEditor Grid.Column="1"
                                KeyCombo="{Binding Editor.KeyCombo, UpdateSourceTrigger=PropertyChanged, Delay=300}"/>
                        </Grid>

                        <!-- Mouse Click -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    Visibility="{Binding Editor.IsMouseClick, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="按键:" VerticalAlignment="Center" Width="45"/>
                            <ComboBox ItemsSource="{Binding Editor.MouseButtons}"
                                      SelectedItem="{Binding Editor.MouseButton}" Width="120"/>
                        </StackPanel>

                        <!-- Mouse Scroll -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    Visibility="{Binding Editor.IsMouseScroll, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="方向:" VerticalAlignment="Center" Width="45"/>
                            <ComboBox ItemsSource="{Binding Editor.ScrollDirections}"
                                      SelectedItem="{Binding Editor.ScrollDirection}" Width="120"/>
                        </StackPanel>

                        <!-- Text -->
                        <Grid Grid.Row="2" Visibility="{Binding Editor.IsText, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="文本:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Editor.Text, UpdateSourceTrigger=PropertyChanged}"
                                     Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Grid>

                        <!-- Rotary: CW + CCW -->
                        <StackPanel Grid.Row="3" Margin="0,8,0,0"
                                    Visibility="{Binding Editor.IsRotary, Converter={StaticResource BoolToVis}}">
                            <StackPanel Margin="0,0,0,6">
                                <TextBlock Text="顺时针 ▲" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding Editor.ActionTypes}"
                                              SelectedItem="{Binding Editor.CwActionType, UpdateSourceTrigger=PropertyChanged}"/>
                                    <controls:KeyComboEditor Grid.Column="1" Margin="8,0,0,0"
                                        KeyCombo="{Binding Editor.CwKeyCombo, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                        Visibility="{Binding Editor.IsCwKeyboard, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="逆时针 ▼" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding Editor.ActionTypes}"
                                              SelectedItem="{Binding Editor.CcwActionType, UpdateSourceTrigger=PropertyChanged}"/>
                                    <controls:KeyComboEditor Grid.Column="1" Margin="8,0,0,0"
                                        KeyCombo="{Binding Editor.CcwKeyCombo, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                        Visibility="{Binding Editor.IsCcwKeyboard, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Save button -->
                        <Button Grid.Row="4" Content="保存" Width="70" Height="28"
                                HorizontalAlignment="Right" Margin="0,10,0,0"
                                Click="EditorSave_Click"
                                Background="#2196F3" Foreground="White" BorderThickness="0"/>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom: Status -->
        <Border Grid.Row="2" Padding="6,3" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock FontSize="10" Foreground="#AAA" TextTrimming="CharacterEllipsis">
                <Run Text="配置: "/>
                <Run Text="{Binding ConfigPath, Mode=OneWay}"/>
            </TextBlock>
        </Border>
    </Grid>
</Window>

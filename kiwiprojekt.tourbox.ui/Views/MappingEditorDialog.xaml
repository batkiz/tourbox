<Window x:Class="kiwiprojekt.tourbox.ui.Views.MappingEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑按键映射" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow" ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontSize="16" FontWeight="Bold">
                <Run Text="配置: "/>
                <Run Text="{Binding ControlLabel}" Foreground="#2196F3"/>
            </TextBlock>
        </StackPanel>

        <!-- Action Type selector -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="动作类型" Style="{StaticResource LabelStyle}"/>
            <ComboBox ItemsSource="{Binding ActionTypes}" SelectedItem="{Binding ActionType}"
                      Height="32"/>
        </StackPanel>

        <!-- Action parameters (changes based on type) -->
        <StackPanel Grid.Row="2">
            <!-- Keyboard -->
            <StackPanel Visibility="{Binding IsKeyboard}">
                <TextBlock Text="按键组合" Style="{StaticResource LabelStyle}"/>
                <TextBlock Text="示例: VK_CONTROL+VK_C  或  VK_BROWSER_BACK"
                           FontSize="10" Foreground="#888" Margin="0,0,0,4"/>
                <TextBox Text="{Binding KeyCombo, UpdateSourceTrigger=PropertyChanged}"
                         Height="30" FontFamily="Consolas"/>
            </StackPanel>

            <!-- Mouse Click -->
            <StackPanel Visibility="{Binding IsMouseClick}">
                <TextBlock Text="鼠标按键" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding MouseButtons}" SelectedItem="{Binding MouseButton}"
                          Height="32"/>
            </StackPanel>

            <!-- Mouse Scroll -->
            <StackPanel Visibility="{Binding IsMouseScroll}">
                <TextBlock Text="滚动方向" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding ScrollDirections}" SelectedItem="{Binding ScrollDirection}"
                          Height="32"/>
            </StackPanel>

            <!-- Text -->
            <StackPanel Visibility="{Binding IsText}">
                <TextBlock Text="文本内容" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         FontFamily="Consolas"/>
            </StackPanel>
        </StackPanel>

        <!-- Mode (Tap/Hold) — only for buttons -->
        <StackPanel Grid.Row="3" Visibility="{Binding ShowMode}" Margin="0,8,0,0">
            <TextBlock Text="触发模式" Style="{StaticResource LabelStyle}"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Tap (按下触发)" IsChecked="{Binding IsTapMode}"
                             GroupName="Mode" Margin="0,0,20,0"/>
                <RadioButton Content="Hold (按住保持)" IsChecked="{Binding IsHoldMode}"
                             GroupName="Mode"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="取消" Width="80" Height="32" Margin="0,0,8,0"
                    IsCancel="True" Click="Cancel_Click"/>
            <Button Content="保存" Width="80" Height="32"
                    IsDefault="True" Click="Save_Click"
                    Background="#2196F3" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
